#!/bin/zsh

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKEND_DIR="$ROOT_DIR/backend"
FRONTEND_DIR="$ROOT_DIR/frontend"
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8001"
FRONTEND_PORT="3000"
BACKEND_ENV="$BACKEND_DIR/.env"
BACKEND_ENV_EXAMPLE="$BACKEND_DIR/.env.example"
FRONTEND_ENV="$FRONTEND_DIR/.env.local"
FRONTEND_ENV_EXAMPLE="$FRONTEND_DIR/.env.local.example"
DEFAULT_DB_PATH="$BACKEND_DIR/data/options_dashboard.sqlite3"

backend_pid=""
frontend_pid=""

cleanup() {
  if [[ -n "$backend_pid" ]] && kill -0 "$backend_pid" 2>/dev/null; then
    kill "$backend_pid" 2>/dev/null || true
  fi

  if [[ -n "$frontend_pid" ]] && kill -0 "$frontend_pid" 2>/dev/null; then
    kill "$frontend_pid" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

copy_if_missing() {
  local target_path="$1"
  local example_path="$2"

  if [[ -f "$target_path" ]]; then
    return
  fi

  if [[ ! -f "$example_path" ]]; then
    echo "Missing required template: $example_path"
    exit 1
  fi

  cp "$example_path" "$target_path"
  echo "Created $target_path from $(basename "$example_path")"
}

db_path_from_env() {
  local configured_path
  configured_path="$(sed -n 's/^LOCAL_DB_PATH=//p' "$BACKEND_ENV" | tail -n 1)"

  if [[ -n "$configured_path" ]]; then
    echo "${configured_path/#\~/$HOME}"
  else
    echo "$DEFAULT_DB_PATH"
  fi
}

warn_if_backend_env_incomplete() {
  local missing=()

  for key in ZERODHA_API_KEY ZERODHA_API_SECRET; do
    if ! grep -q "^${key}=.\+" "$BACKEND_ENV"; then
      missing+=("$key")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    echo "Backend .env still needs values: ${missing[*]}"
    echo "The app can start, but Zerodha login and live market fetches will not work until those are set."
  fi
}

describe_db_state() {
  local db_path="$1"

  if [[ -f "$db_path" ]]; then
    echo "Using SQLite DB at $db_path"
    return
  fi

  echo "No SQLite DB found at $db_path"
  echo "The backend will create a fresh schema automatically on startup."
  echo "If you want existing history and saved runtime settings, copy backend/data/options_dashboard.sqlite3 from the old laptop first."
}

echo "Starting Options Dashboard from $ROOT_DIR"

copy_if_missing "$BACKEND_ENV" "$BACKEND_ENV_EXAMPLE"
copy_if_missing "$FRONTEND_ENV" "$FRONTEND_ENV_EXAMPLE"
warn_if_backend_env_incomplete
describe_db_state "$(db_path_from_env)"

if [[ ! -d "$BACKEND_DIR/.venv" ]]; then
  echo "Creating backend virtual environment..."
  (
    cd "$BACKEND_DIR"
    python3 -m venv .venv
  )
fi

if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
  echo "Installing frontend dependencies..."
  (
    cd "$FRONTEND_DIR"
    npm install
  )
fi

echo "Installing backend dependencies..."
(
  cd "$BACKEND_DIR"
  source .venv/bin/activate
  pip install -r requirements.txt >/dev/null
)

echo "Launching backend on http://$BACKEND_HOST:$BACKEND_PORT"
(
  cd "$BACKEND_DIR"
  source .venv/bin/activate
  exec uvicorn main:app --reload --host "$BACKEND_HOST" --port "$BACKEND_PORT"
) &
backend_pid=$!

echo "Launching frontend on http://localhost:$FRONTEND_PORT"
(
  cd "$FRONTEND_DIR"
  exec npm run dev
) &
frontend_pid=$!

echo "Backend PID: $backend_pid"
echo "Frontend PID: $frontend_pid"
echo "Press Ctrl+C to stop both services."

wait "$backend_pid" "$frontend_pid"
